# === Monorepo .gitignore (Go backend + Taro miniapp) ===

# ----- Planning / IDE -----
.planning/
.trae/
.idea/
.vscode/
*.swp
*.swo
CONTEXT.md

# ----- OS -----
.DS_Store
Thumbs.db

# ----- Office lock files -----
**/.~lock.*#

# ----- Secrets / Local env (root level) -----
.env
.env.local
*.local

# ----- Go (backend) -----
*.exe
*.exe~
*.dll
*.so
*.dylib
*.out
/bin/
/vendor/
go.work.sum

# Go test binaries (only in root / cmd / internal)
/test/*.test
/cmd/**/*.test
/internal/**/*.test

# Backend specific
/backend/bin/
/backend/vendor/
/backend/.env
/backend/.env.local
/backend/*.local
/backend/tmp/
/backend/*.log

# ----- Build / Cache (root level) -----
/tmp/
*.log

# ----- Node / pnpm (monorepo) -----
node_modules/

# ----- Taro miniapp build output -----
miniapp/dist/
miniapp/deploy_versions/
miniapp/.temp/
miniapp/.rn_temp/

# ----- Taro miniapp tooling cache -----
miniapp/.swc/
miniapp/.eslintcache
miniapp/.stylelintcache

# ----- Husky internal -----
miniapp/.husky/_

# ---- Misc ----
backend/pickup-server
